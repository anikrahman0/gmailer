{
    "manifest_version": 3,
    "name": "Gmailer",
    "version": "2.0",
    "description": "Gmail notifications with sound",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "identity",
        "notifications",
        "storage",
        "offscreen"
    ],
    "host_permissions": [
        "https://gmail.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Gmailer",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "oauth2": {
        "client_id": "YOUR_CLIENT_ID_HERE.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/gmail.readonly"
        ]
    }
}
